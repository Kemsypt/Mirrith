      const prof = state.saves[key]?.prof ? state.proficiencyBonus : 0;
      return mod + prof;
    }
    function calcSkill(skill){
      const mod = abilityMod(skill.abil);
      const prof = skill.prof ? state.proficiencyBonus : 0;
      return mod + prof;
    }

