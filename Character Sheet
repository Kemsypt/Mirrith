<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mirr’ith Alistr’yn • Level 1 Wizard (5e)</title>
  <style>
    :root{
      --bg:#0b0d12;
      --panel:rgba(20,22,30,.78);
      --panel2:rgba(20,22,30,.62);
      --text:#eef0f6;
      --muted:rgba(238,240,246,.72);
      --border:rgba(238,240,246,.16);
      --shadow:0 14px 40px rgba(0,0,0,.45);
      --radius:16px;
      --accent:#8f5bff;
      --accent2:#c152ff;
      --good:#50e3a4;
      --warn:#ffcc66;
      --bad:#ff6b6b;
      --hp:var(--good);
      --hp2:rgba(80,227,164,.78);
      --font:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
      --mono:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
    }
    [data-theme="ink-violet"]{ --bg:#0b0d12; --panel:rgba(14,16,24,.78); --panel2:rgba(14,16,24,.62); --text:#eef0f6; --muted:rgba(238,240,246,.72); --border:rgba(238,240,246,.16); --accent:#8f5bff; --accent2:#c152ff; }
    [data-theme="parchment-crimson"]{ --bg:#17130e; --panel:rgba(35,28,20,.82); --panel2:rgba(35,28,20,.62); --text:#fff4e6; --muted:rgba(255,244,230,.72); --border:rgba(255,244,230,.16); --accent:#ff4d6d; --accent2:#ff9aa8; }
    [data-theme="glass-teal"]{ --bg:#071018; --panel:rgba(7,24,28,.74); --panel2:rgba(7,24,28,.56); --text:#e9fbff; --muted:rgba(233,251,255,.70); --border:rgba(233,251,255,.16); --accent:#19d3d3; --accent2:#80fff0; }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{ margin:0; font-family:var(--font); color:var(--text); background:var(--bg); overflow-x:hidden; }

    .bg{ position:fixed; inset:0; background-image:url('https://i.imgur.com/MHPPfK1.jpeg'); background-size:cover; background-position:center; background-attachment:fixed; filter:saturate(.95) contrast(1.05) brightness(.72); transform:scale(1.04); z-index:-3; }
    .bg::after{ content:""; position:absolute; inset:0; background:
      radial-gradient(1200px 700px at 30% 10%, rgba(255,255,255,.10), transparent 60%),
      radial-gradient(900px 650px at 80% 30%, rgba(0,0,0,.25), transparent 60%),
      linear-gradient(to bottom, rgba(0,0,0,.55), rgba(0,0,0,.70));
    }

    .wrap{ max-width:1180px; margin:0 auto; padding:22px 16px 54px; }
    header{ display:grid; grid-template-columns:1fr 340px; gap:14px; align-items:stretch; }

    .card{ background:var(--panel); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); overflow:hidden; }
    .titleCard{ padding:16px 16px 14px; }
    .titleRow{ display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
    h1{ margin:0; font-size:clamp(22px,3.2vw,30px); letter-spacing:.2px; }
    .sub{ margin-top:6px; color:var(--muted); font-size:13.5px; display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
    .pill{ display:inline-flex; align-items:center; gap:8px; padding:6px 10px; border-radius:999px; background:rgba(255,255,255,.06); border:1px solid var(--border); font-size:12.5px; color:var(--text); }
    .dot{ width:8px; height:8px; border-radius:999px; background:var(--accent); box-shadow:0 0 0 3px rgba(255,255,255,.06); }

    .row{ display:flex; flex-wrap:wrap; gap:10px; margin-top:12px; }
    .field{ display:flex; gap:8px; align-items:center; background:rgba(255,255,255,.05); border:1px solid var(--border); border-radius:12px; padding:10px; flex:1 1 180px; min-width:160px; }
    .field label{ font-size:11.5px; color:var(--muted); display:block; }
    .field input,.field select{ width:100%; background:transparent; color:var(--text); border:none; outline:none; font-size:14px; font-weight:650; }
    .field input::placeholder{ color:rgba(255,255,255,.45); }

    .portrait{ display:grid; grid-template-rows:auto 1fr; }
    .portraitTop{ padding:14px 14px 10px; display:flex; align-items:center; justify-content:space-between; gap:10px; border-bottom:1px solid var(--border); background:linear-gradient(120deg, rgba(255,255,255,.05), transparent); }
    .portraitTop .themeRow{ display:flex; gap:8px; align-items:center; }
    .themeBtn{ width:34px; height:34px; border-radius:12px; border:1px solid var(--border); background:rgba(255,255,255,.06); cursor:pointer; display:grid; place-items:center; transition:transform 120ms ease, background 120ms ease; }
    .themeBtn:active{ transform:scale(.98); }
    .themeSwatch{ width:14px; height:14px; border-radius:999px; background:var(--accent); box-shadow:0 0 0 4px rgba(255,255,255,.08); }
    .portraitImg{ position:relative; background:rgba(0,0,0,.28); }
    .portraitImg img{ width:100%; height:100%; object-fit:cover; display:block; filter:contrast(1.02) saturate(1.03); }
    .portraitBadge{ position:absolute; bottom:12px; left:12px; right:12px; padding:10px 12px; border-radius:14px; background:rgba(0,0,0,.58); border:1px solid rgba(255,255,255,.16); backdrop-filter:blur(10px); }
    .portraitBadge .small{ color:rgba(255,255,255,.78); font-size:12px; }
    .portraitBadge .big{ font-size:14px; font-weight:700; margin-top:4px; }

    .tabs{ margin-top:14px; }
    .tabBar{ display:flex; gap:8px; flex-wrap:wrap; padding:10px; background:var(--panel2); border:1px solid var(--border); border-radius:16px; box-shadow:var(--shadow); }
    .tabBtn{ border:1px solid var(--border); background:rgba(255,255,255,.06); color:var(--text); padding:10px 12px; border-radius:14px; cursor:pointer; font-weight:650; font-size:13px; transition:background 120ms ease, transform 120ms ease; }
    .tabBtn:hover{ background:rgba(255,255,255,.09); }
    .tabBtn:active{ transform:scale(.99); }
    .tabBtn[aria-selected="true"]{ background:linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.05)); border-color:rgba(255,255,255,.28); box-shadow:inset 0 0 0 1px rgba(255,255,255,.08); }
    .tabPanel{ display:none; margin-top:12px; }
    .tabPanel.active{ display:block; }

    .stack{ display:grid; gap:12px; }
    .section{ padding:14px; }
    .section h2{ margin:0 0 10px; font-size:14px; letter-spacing:.2px; color:rgba(255,255,255,.92); display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .hint{ color:var(--muted); font-size:12px; font-weight:500; }
    .list{ display:grid; gap:10px; }
    .kv{ display:flex; justify-content:space-between; gap:12px; padding:10px 12px; border-radius:14px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .kv .k{ color:var(--muted); font-size:12px; }
    .kv .v{ font-weight:750; }

    .hpBox{ padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .hpRow{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .hpRow .num{ display:flex; gap:8px; align-items:center; }
    .hpRow input{ width:84px; padding:10px; border-radius:12px; border:1px solid var(--border); background:rgba(0,0,0,.25); color:var(--text); outline:none; font-weight:800; font-size:14px; }
    .hpBar{ margin-top:10px; height:16px; border-radius:999px; border:1px solid var(--border); background:rgba(0,0,0,.30); overflow:hidden; position:relative; }
    .hpFill{ height:100%; width:100%; background:linear-gradient(90deg, var(--hp), var(--hp2)); border-radius:999px; transition:width 180ms ease; }
    .hpMeta{ display:flex; justify-content:space-between; margin-top:8px; color:var(--muted); font-size:12px; }

    .miniGrid{ display:grid; grid-template-columns:repeat(6,1fr); gap:10px; }
    .stat{ padding:12px; border:1px solid var(--border); background:rgba(255,255,255,.05); border-radius:14px; display:grid; gap:8px; user-select:none; }
    .stat .main{ display:grid; gap:6px; cursor:pointer; padding:6px; border-radius:12px; transition:background 120ms ease; }
    .stat .main:hover{ background:rgba(255,255,255,.06); }
    .stat .top{ display:flex; align-items:baseline; justify-content:space-between; gap:10px; }
    .stat .name{ color:var(--muted); font-size:11.5px; letter-spacing:.5px; }
    .stat .score{ font-size:18px; font-weight:800; }
    .stat .mod{ font-family:var(--mono); font-size:12.5px; color:rgba(255,255,255,.85); }

    .saveLine{ display:flex; align-items:center; justify-content:space-between; gap:8px; padding:8px 10px; border-radius:12px; border:1px solid rgba(255,255,255,.14); background:rgba(0,0,0,.18); cursor:pointer; transition:background 120ms ease, transform 120ms ease; }
    .saveLine:hover{ background:rgba(255,255,255,.06); }
    .saveLine:active{ transform:scale(.99); }
    .saveLine .lbl{ color:var(--muted); font-size:12px; font-weight:650; }
    .saveLine .right{ display:flex; align-items:center; gap:8px; }
    .proBadge{ font-size:11px; padding:4px 8px; border-radius:999px; border:1px solid var(--border); background:rgba(0,0,0,.20); color:var(--muted); min-width:44px; text-align:center; }
    .proBadge.on{ color:rgba(255,255,255,.92); border-color:rgba(255,255,255,.28); background:rgba(255,255,255,.10); }
    .saveLine .bonus{ font-family:var(--mono); font-weight:900; }

    .skillGrid{ display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
    .skill{ padding:10px 12px; border-radius:14px; border:1px solid var(--border); background:rgba(255,255,255,.05); display:flex; align-items:center; justify-content:space-between; gap:10px; cursor:pointer; user-select:none; transition:transform 120ms ease, background 120ms ease; }
    .skill:hover{ background:rgba(255,255,255,.07); }
    .skill:active{ transform:scale(.99); }
    .skill .left{ display:flex; gap:10px; align-items:center; min-width:0; }
    .skill .nm{ font-weight:850; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .skill .ab{ color:var(--muted); font-size:12px; }
    .skill .right{ display:flex; gap:8px; align-items:center; }
    .skill .bonus{ font-family:var(--mono); font-weight:900; }

    .spellHeaderRow{ display:flex; flex-wrap:wrap; gap:10px; align-items:center; justify-content:space-between; }
    .counter{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .countBox{ padding:8px 10px; border-radius:14px; border:1px solid var(--border); background:rgba(255,255,255,.06); font-size:12.5px; }
    .spellGrid{ display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }
    .spellCard{ padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .spellTop{ display:flex; align-items:flex-start; justify-content:space-between; gap:10px; }
    .spellName{ font-weight:850; letter-spacing:.2px; }
    .tagRow{ display:flex; flex-wrap:wrap; gap:6px; margin-top:6px; }
    .tag{ font-size:11.5px; color:var(--muted); border:1px solid var(--border); background:rgba(0,0,0,.20); padding:4px 8px; border-radius:999px; }
    details{ margin-top:10px; }
    details summary{ cursor:pointer; color:rgba(255,255,255,.88); font-weight:700; }
    .spellBody{ margin-top:10px; color:rgba(255,255,255,.86); font-size:13px; line-height:1.45; }
    .spellBody .line{ margin:6px 0; }
    .spellBody .lbl{ color:var(--muted); font-weight:650; }

    .btn{ border:1px solid var(--border); background:rgba(255,255,255,.06); color:var(--text); padding:10px 12px; border-radius:14px; cursor:pointer; font-weight:700; font-size:13px; transition:background 120ms ease, transform 120ms ease; user-select:none; }
    .btn:hover{ background:rgba(255,255,255,.09); }
    .btn:active{ transform:scale(.99); }
    .btn.small{ padding:8px 10px; font-size:12px; border-radius:12px; }
    .btn.primary{ background:linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.05)); border-color:rgba(255,255,255,.28); }

    .slots{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:10px; padding:10px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .slotDots{ display:flex; gap:8px; align-items:center; }
    .slotDot{ width:18px; height:18px; border-radius:999px; border:1px solid rgba(255,255,255,.22); background:rgba(255,255,255,.08); cursor:pointer; transition:transform 120ms ease; }
    .slotDot:active{ transform:scale(.96); }
    .slotDot.used{ background:rgba(255,255,255,.10); opacity:.42; }
    .slotDot.available{ background:var(--accent); box-shadow:0 0 0 3px rgba(255,255,255,.07); }
    .stepper{ display:flex; gap:6px; align-items:center; }
    .stepper .num{ min-width:28px; text-align:center; font-weight:900; }

    .notesGrid{ display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }
    .noteCard{ padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .noteCardHead{ display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:8px; }
    .noteCardHead .ttl{ font-weight:900; }
    textarea{ width:100%; min-height:170px; resize:vertical; padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(0,0,0,.25); color:var(--text); outline:none; font-size:13px; line-height:1.45; }

    .invCols{ display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
    .invCol{ padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); min-height:220px; }
    .invCol h3{ margin:0 0 10px; font-size:13.5px; display:flex; justify-content:space-between; align-items:center; gap:10px; }
    .invCol .small{ color:var(--muted); font-size:11.5px; }
    .invItem{ padding:10px; border-radius:14px; border:1px solid var(--border); background:rgba(0,0,0,.22); margin-bottom:10px; cursor:grab; }
    .invItem:active{ cursor:grabbing; }
    .invItem .name{ font-weight:850; }
    .invItem .meta{ margin-top:4px; font-size:12px; color:var(--muted); display:flex; justify-content:space-between; gap:8px; }
    .invItem .actions{ margin-top:8px; display:flex; gap:8px; flex-wrap:wrap; }

    .invForm{ padding:14px; }
    .invForm .row2{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .invForm .row3{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; }
    .input{ width:100%; padding:10px 12px; border-radius:14px; border:1px solid var(--border); background:rgba(0,0,0,.25); color:var(--text); outline:none; font-weight:650; font-size:13px; }

    .footerRow{ margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; align-items:center; justify-content:space-between; }
    .saveHint{ color:var(--muted); font-size:12px; }

    .diceFab{ position:fixed; right:10px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:14px; border:1px solid var(--border); background:rgba(255,255,255,.08); backdrop-filter:blur(10px); display:grid; place-items:center; cursor:pointer; z-index:50; box-shadow:0 12px 30px rgba(0,0,0,.40); transition:transform 120ms ease, background 120ms ease; }
    .diceFab:hover{ background:rgba(255,255,255,.10); }
    .diceFab:active{ transform:translateY(-50%) scale(.98); }
    .diceFab svg{ width:22px; height:22px; fill:none; stroke:rgba(255,255,255,.92); stroke-width:2; }

    .drawerOverlay{ position:fixed; inset:0; background:rgba(0,0,0,.50); opacity:0; pointer-events:none; transition:opacity 180ms ease; z-index:60; }
    .drawerOverlay.on{ opacity:1; pointer-events:auto; }
    .drawer{ position:fixed; top:0; right:0; height:100%; width:min(420px,92vw); transform:translateX(102%); transition:transform 220ms ease; z-index:70; display:flex; flex-direction:column; background:rgba(15,18,26,.92); border-left:1px solid rgba(255,255,255,.14); box-shadow:-18px 0 40px rgba(0,0,0,.45); backdrop-filter:blur(12px); }
    body[data-theme="parchment-crimson"] .drawer{ background:rgba(38,30,22,.92); }
    body[data-theme="glass-teal"] .drawer{ background:rgba(7,28,30,.92); }
    .drawer.on{ transform:translateX(0); }
    .drawerHead{ padding:14px 14px 10px; display:flex; align-items:center; justify-content:space-between; gap:10px; border-bottom:1px solid rgba(255,255,255,.14); }
    .drawerHead .ttl{ font-weight:900; letter-spacing:.2px; }
    .drawerBody{ padding:14px; overflow:auto; }
    .drawerClose{ width:38px; height:38px; border-radius:14px; border:1px solid rgba(255,255,255,.16); background:rgba(255,255,255,.06); color:rgba(255,255,255,.92); cursor:pointer; display:grid; place-items:center; }
    .diceTop{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .rollAnim{ display:flex; align-items:center; justify-content:center; border-radius:18px; border:1px solid rgba(255,255,255,.16); background:rgba(0,0,0,.25); min-height:120px; position:relative; overflow:hidden; margin-top:12px; }
    .rollAnim .big{ font-size:46px; font-weight:900; letter-spacing:.5px; text-shadow:0 10px 30px rgba(0,0,0,.45); }
    .rollAnim .small{ position:absolute; bottom:10px; left:12px; right:12px; display:flex; justify-content:space-between; color:var(--muted); font-size:12px; }
    .log{ margin-top:10px; padding:10px; border-radius:16px; border:1px solid rgba(255,255,255,.14); background:rgba(255,255,255,.05); max-height:220px; overflow:auto; font-family:var(--mono); font-size:12px; line-height:1.35; white-space:pre-wrap; }

    .pop{ position:fixed; inset:0; display:grid; place-items:center; pointer-events:none; z-index:90; }
    .popCard{ pointer-events:none; width:min(420px,92vw); border-radius:20px; border:1px solid rgba(255,255,255,.18); background:rgba(0,0,0,.68); backdrop-filter:blur(12px); box-shadow:0 24px 60px rgba(0,0,0,.55); padding:16px 16px 14px; transform:translateY(14px) scale(.98); opacity:0; transition:opacity 180ms ease, transform 180ms ease; overflow:hidden; position:relative; }
    .popCard.on{ opacity:1; transform:translateY(0) scale(1); }
    .popGlow{ position:absolute; inset:-40px; background:
      radial-gradient(420px 240px at 30% 30%, rgba(255,255,255,.12), transparent 60%),
      radial-gradient(520px 320px at 70% 20%, rgba(255,255,255,.08), transparent 62%);
      opacity:.9;
    }
    .popMain{ position:relative; display:flex; gap:14px; align-items:center; }
    .popNum{ width:74px; height:74px; border-radius:18px; display:grid; place-items:center; font-size:34px; font-weight:950; border:1px solid rgba(255,255,255,.18); background:rgba(255,255,255,.06); box-shadow:inset 0 0 0 1px rgba(255,255,255,.06); }
    .popText{ flex:1; min-width:0; }
    .popTitle{ font-weight:900; letter-spacing:.2px; }
    .popDetail{ margin-top:4px; color:rgba(255,255,255,.78); font-size:13px; line-height:1.35; }
    .popHint{ margin-top:8px; color:rgba(255,255,255,.62); font-size:12px; }
    .popCard[data-tone="green"] .popNum{ border-color:rgba(80,227,164,.55); box-shadow:0 0 0 4px rgba(80,227,164,.10); }
    .popCard[data-tone="red"] .popNum{ border-color:rgba(255,107,107,.55); box-shadow:0 0 0 4px rgba(255,107,107,.10); }

    .modalOverlay{ position:fixed; inset:0; background:rgba(0,0,0,.55); opacity:0; pointer-events:none; transition:opacity 160ms ease; z-index:95; }
    .modalOverlay.on{ opacity:1; pointer-events:auto; }
    .modal{ position:fixed; inset:0; display:grid; place-items:center; z-index:96; pointer-events:none; }
    .modalCard{ pointer-events:auto; width:min(560px,94vw); border-radius:22px; border:1px solid rgba(255,255,255,.18); background:rgba(12,14,20,.92); backdrop-filter:blur(14px); box-shadow:0 30px 80px rgba(0,0,0,.60); overflow:hidden; transform:translateY(10px) scale(.985); opacity:0; transition:opacity 160ms ease, transform 160ms ease; }
    body[data-theme="parchment-crimson"] .modalCard{ background:rgba(28,22,16,.92); }
    body[data-theme="glass-teal"] .modalCard{ background:rgba(7,22,24,.92); }
    .modalCard.on{ opacity:1; transform:translateY(0) scale(1); }
    .modalHead{ padding:14px 14px 12px; display:flex; align-items:center; justify-content:space-between; gap:10px; border-bottom:1px solid rgba(255,255,255,.14); background:linear-gradient(120deg, rgba(255,255,255,.06), transparent); }
    .modalHead .ttl{ font-weight:950; letter-spacing:.2px; }
    .modalBody{ padding:14px; display:grid; gap:10px; }
    .modalFoot{ padding:12px 14px; border-top:1px solid rgba(255,255,255,.14); display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; background:rgba(255,255,255,.04); }
    .danger{ border-color:rgba(255,107,107,.35) !important; background:rgba(255,107,107,.10) !important; }

    .familiarGrid{ display:grid; gap:12px; }
    .statBlock{ padding:12px; border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,.05); }
    .statBlock details{ margin-top:8px; }
    .blockLine{ margin:6px 0; color:rgba(255,255,255,.86); font-size:13px; line-height:1.45; }
    .blockLine .lbl{ color:var(--muted); font-weight:700; }

    @media (max-width:980px){
      header{ grid-template-columns:1fr; }
      .spellGrid{ grid-template-columns:1fr; }
      .notesGrid{ grid-template-columns:1fr; }
      .invCols{ grid-template-columns:1fr 1fr; }
      .miniGrid{ grid-template-columns:repeat(3,1fr); }
      .skillGrid{ grid-template-columns:repeat(2,1fr); }
    }
    @media (max-width:560px){
      .invCols{ grid-template-columns:1fr; }
      .miniGrid{ grid-template-columns:repeat(2,1fr); }
      .skillGrid{ grid-template-columns:1fr; }
      .diceFab{ right:8px; }
      .invForm .row2,.invForm .row3{ grid-template-columns:1fr; }
    }
  </style>
</head>

<body data-theme="ink-violet">
  <div class="bg" aria-hidden="true"></div>

  <div class="wrap">
    <header>
      <section class="card titleCard">
