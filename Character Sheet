    function addRollLog(line){
      const log=document.getElementById("rollLog");
      const stamp=new Date().toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"});
      const entry=`[${stamp}] ${line}`;
      state.ui.rollLog.unshift(entry);
