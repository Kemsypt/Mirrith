<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mirr’ith Alistr’yn • Level 1 Wizard (5e)</title>
  <style>
    :root{
      --bg: #0b0d12;
      --panel: rgba(20, 22, 30, 0.78);
      --panel2: rgba(20, 22, 30, 0.62);
      --text: #eef0f6;
      --muted: rgba(238,240,246,0.72);
      --border: rgba(238,240,246,0.16);
      --shadow: 0 14px 40px rgba(0,0,0,0.45);
      --radius: 16px;
      --accent: #8f5bff;
      --accent2: #c152ff;
      --good: #50e3a4;
      --warn: #ffcc66;
      --bad: #ff6b6b;
      --hp: #50e3a4;
      --hp2: #2fbf7e;

      --font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    [data-theme="ink-violet"]{
      --bg: #0b0d12;
      --panel: rgba(14, 16, 24, 0.78);
      --panel2: rgba(14, 16, 24, 0.62);
      --text: #eef0f6;
      --muted: rgba(238,240,246,0.72);
      --border: rgba(238,240,246,0.16);
      --accent: #8f5bff;
      --accent2: #c152ff;
    }
    [data-theme="parchment-crimson"]{
      --bg: #17130e;
      --panel: rgba(35, 28, 20, 0.82);
      --panel2: rgba(35, 28, 20, 0.62);
      --text: #fff4e6;
      --muted: rgba(255,244,230,0.72);
      --border: rgba(255,244,230,0.16);
      --accent: #ff4d6d;
      --accent2: #ff9aa8;
    }
    [data-theme="glass-teal"]{
      --bg: #071018;
      --panel: rgba(7, 24, 28, 0.74);
      --panel2: rgba(7, 24, 28, 0.56);
      --text: #e9fbff;
      --muted: rgba(233,251,255,0.70);
      --border: rgba(233,251,255,0.16);
      --accent: #19d3d3;
      --accent2: #80fff0;
    }

    *{ box-sizing: border-box; }
    html, body{ height: 100%; }
    body{
      margin: 0;
      font-family: var(--font);
      color: var(--text);
      background: var(--bg);
      overflow-x: hidden;
    }

    .bg{
      position: fixed;
      inset: 0;
      background-image: url('https://i.imgur.com/MHPPfK1.jpeg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      filter: saturate(0.95) contrast(1.05) brightness(0.72);
      transform: scale(1.04);
      z-index: -3;
    }
    .bg::after{
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(1200px 700px at 30% 10%, rgba(255,255,255,0.10), transparent 60%),
                  radial-gradient(900px 650px at 80% 30%, rgba(0,0,0,0.25), transparent 60%),
                  linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.70));
    }

    .wrap{
      max-width: 1180px;
      margin: 0 auto;
      padding: 22px 16px 54px;
    }

    header{
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 14px;
      align-items: stretch;
    }

    .card{
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .titleCard{ padding: 16px 16px 14px; position: relative; }
    .titleRow{ display:flex; align-items:flex-start; justify-content: space-between; gap: 12px; }
    h1{
      margin: 0;
      font-size: clamp(22px, 3.2vw, 30px);
      letter-spacing: 0.2px;
    }
    .sub{
      margin-top: 6px;
      color: var(--muted);
      font-size: 13.5px;
      display:flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .pill{
      display:inline-flex;
      align-items:center;
      gap: 8px;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--border);
      font-size: 12.5px;
      color: var(--text);
    }
    .dot{ width: 8px; height: 8px; border-radius: 999px; background: var(--accent); box-shadow: 0 0 0 3px rgba(255,255,255,0.06); }

    .row{
      display:flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 12px;
    }

    .field{
      display:flex;
      gap: 8px;
      align-items: center;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 10px 10px;
      flex: 1 1 180px;
      min-width: 160px;
    }
    .field label{ font-size: 11.5px; color: var(--muted); display:block; }
    .field .value{ font-weight: 650; font-size: 14px; }
    .field input, .field select{
      width: 100%;
      background: transparent;
      color: var(--text);
      border: none;
      outline: none;
      font-size: 14px;
      font-weight: 650;
    }
    .field input::placeholder{ color: rgba(255,255,255,0.45); }

    .portrait{
      display:grid;
      grid-template-rows: auto 1fr;
    }
    .portraitTop{
      padding: 14px 14px 10px;
      display:flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(120deg, rgba(255,255,255,0.05), transparent);
    }
    .portraitTop .themeRow{ display:flex; gap: 8px; align-items:center; }
    .themeBtn{
      width: 34px;
      height: 34px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.06);
      cursor: pointer;
      display:grid;
      place-items:center;
      transition: transform 120ms ease, background 120ms ease;
    }
    .themeBtn:active{ transform: scale(0.98); }
    .themeSwatch{
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(255,255,255,0.08);
    }
    .portraitImg{
      position: relative;
      background: rgba(0,0,0,0.28);
    }
    .portraitImg img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      display:block;
      filter: contrast(1.02) saturate(1.03);
    }
    .portraitBadge{
      position:absolute;
      bottom: 12px;
      left: 12px;
      right: 12px;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(0,0,0,0.58);
      border: 1px solid rgba(255,255,255,0.16);
      backdrop-filter: blur(10px);
    }
    .portraitBadge .small{ color: rgba(255,255,255,0.78); font-size: 12px; }
    .portraitBadge .big{ font-size: 14px; font-weight: 700; margin-top: 4px; }

    .tabs{ margin-top: 14px; }
    .tabBar{
      display:flex;
      gap: 8px;
      flex-wrap: wrap;
      padding: 10px;
      background: var(--panel2);
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: var(--shadow);
    }
    .tabBtn{
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.06);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 14px;
      cursor: pointer;
      font-weight: 650;
      font-size: 13px;
      transition: background 120ms ease, transform 120ms ease;
    }
    .tabBtn:hover{ background: rgba(255,255,255,0.09); }
    .tabBtn:active{ transform: scale(0.99); }
    .tabBtn[aria-selected="true"]{
      background: linear-gradient(135deg, rgba(255,255,255,0.10), rgba(255,255,255,0.05));
      border-color: rgba(255,255,255,0.28);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
    }

    .tabPanel{ display:none; margin-top: 12px; }
    .tabPanel.active{ display:block; }

    .stack{ display:grid; gap: 12px; }
    .section{ padding: 14px; }
    .section h2{
      margin: 0 0 10px;
      font-size: 14px;
      letter-spacing: 0.2px;
      color: rgba(255,255,255,0.92);
      display:flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .hint{ color: var(--muted); font-size: 12px; font-weight: 500; }

    .list{ display:grid; gap: 10px; }

    .kv{
      display:flex;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
    }
    .kv .k{ color: var(--muted); font-size: 12px; }
    .kv .v{ font-weight: 750; }

    .chip{
      display:inline-flex;
      align-items:center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.06);
      cursor: pointer;
      user-select: none;
      font-size: 12.5px;
      font-weight: 750;
      transition: transform 120ms ease, background 120ms ease;
    }
    .chip:hover{ background: rgba(255,255,255,0.09); }
    .chip:active{ transform: scale(0.99); }
    .chip .mark{ width: 10px; height: 10px; border-radius: 999px; background: rgba(255,255,255,0.22); border: 1px solid rgba(255,255,255,0.18); }
    .chip[data-pro="true"] .mark{ background: var(--accent); box-shadow: 0 0 0 3px rgba(255,255,255,0.07); }

    .hpBox{ padding: 12px; border-radius: 16px; border: 1px solid var(--border); background: rgba(255,255,255,0.05); }
    .hpRow{ display:flex; gap: 10px; flex-wrap: wrap; align-items:center; }
    .hpRow .num{ display:flex; gap: 8px; align-items:center; }
    .hpRow input{
      width: 84px;
      padding: 10px 10px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.25);
      color: var(--text);
      outline: none;
      font-weight: 800;
      font-size: 14px;
    }
    .hpBar{
      margin-top: 10px;
      height: 16px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.30);
      overflow: hidden;
      position: relative;
    }
    .hpFill{
      height: 100%;
      width: 100%;
      background: linear-gradient(90deg, var(--hp), var(--hp2));
      border-radius: 999px;
      transition: width 180ms ease;
    }
    .hpMeta{ display:flex; justify-content: space-between; margin-top: 8px; color: var(--muted); font-size: 12px; }

    .miniGrid{
      display:grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
    }
    .stat{
      padding: 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
      border-radius: 14px;
      display:grid;
      gap: 6px;
      cursor: pointer;
      user-select: none;
      transition: transform 120ms ease, background 120ms ease;
    }
    .stat:hover{ background: rgba(255,255,255,0.07); }
    .stat:active{ transform: scale(0.99); }
    .stat .top{ display:flex; align-items:baseline; justify-content: space-between; gap: 10px; }
    .stat .name{ color: var(--muted); font-size: 11.5px; letter-spacing: 0.5px; }
    .stat .score{ font-size: 18px; font-weight: 800; }
    .stat .mod{ font-family: var(--mono); font-size: 12.5px; color: rgba(255,255,255,0.85); }

    .skillGrid{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .skill{
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 10px;
      cursor: pointer;
      user-select: none;
      transition: transform 120ms ease, background 120ms ease;
    }
    .skill:hover{ background: rgba(255,255,255,0.07); }
    .skill:active{ transform: scale(0.99); }
    .skill .left{ display:flex; gap: 10px; align-items:center; min-width: 0; }
    .skill .nm{ font-weight: 850; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .skill .ab{ color: var(--muted); font-size: 12px; }
    .skill .right{ display:flex; gap: 8px; align-items:center; }
    .skill .bonus{ font-family: var(--mono); font-weight: 900; }
    .proBadge{
      font-size: 11px;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.20);
      color: var(--muted);
    }
    .proBadge.on{
      color: rgba(255,255,255,0.92);
      border-color: rgba(255,255,255,0.28);
      background: rgba(255,255,255,0.10);
    }

    .spellHeaderRow{ display:flex; flex-wrap: wrap; gap: 10px; align-items:center; justify-content: space-between; }
    .counter{ display:flex; gap: 10px; flex-wrap: wrap; align-items:center; }
    .countBox{ padding: 8px 10px; border-radius: 14px; border: 1px solid var(--border); background: rgba(255,255,255,0.06); font-size: 12.5px; }
    .spellGrid{ display:grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .spellCard{ padding: 12px; border-radius: 16px; border: 1px solid var(--border); background: rgba(255,255,255,0.05); }
    .spellTop{ display:flex; align-items:flex-start; justify-content: space-between; gap: 10px; }
    .spellName{ font-weight: 850; letter-spacing: 0.2px; }
    .tagRow{ display:flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
    .tag{ font-size: 11.5px; color: var(--muted); border: 1px solid var(--border); background: rgba(0,0,0,0.20); padding: 4px 8px; border-radius: 999px; }
    details{ margin-top: 10px; }
    details summary{ cursor: pointer; color: rgba(255,255,255,0.88); font-weight: 700; }
    .spellBody{ margin-top: 10px; color: rgba(255,255,255,0.86); font-size: 13px; line-height: 1.45; }
    .spellBody .line{ margin: 6px 0; }
    .spellBody .lbl{ color: var(--muted); font-weight: 650; }

    .btn{
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.06);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 14px;
      cursor: pointer;
      font-weight: 700;
      font-size: 13px;
      transition: background 120ms ease, transform 120ms ease;
      user-select: none;
    }
    .btn:hover{ background: rgba(255,255,255,0.09); }
    .btn:active{ transform: scale(0.99); }
    .btn.small{ padding: 8px 10px; font-size: 12px; border-radius: 12px; }
    .btn.primary{
      background: linear-gradient(135deg, rgba(255,255,255,0.10), rgba(255,255,255,0.05));
      border-color: rgba(255,255,255,0.28);
    }

    .slots{
      display:flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 10px;
      padding: 10px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
    }
    .slotDots{ display:flex; gap: 8px; align-items:center; }
    .slotDot{
      width: 18px;
      height: 18px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.22);
      background: rgba(255,255,255,0.08);
      cursor: pointer;
      transition: transform 120ms ease;
    }
    .slotDot:active{ transform: scale(0.96); }
    .slotDot.used{ background: rgba(255,255,255,0.10); opacity: 0.42; }
    .slotDot.available{ background: var(--accent); box-shadow: 0 0 0 3px rgba(255,255,255,0.07); }

    .stepper{ display:flex; gap: 6px; align-items:center; }
    .stepper .num{ min-width: 28px; text-align:center; font-weight: 900; }

    .notesGrid{ display:grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .noteCard{
      padding: 12px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
    }
    .noteCardHead{
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }
    .noteCardHead .ttl{ font-weight: 900; }
    textarea{
      width: 100%;
      min-height: 170px;
      resize: vertical;
      padding: 12px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.25);
      color: var(--text);
      outline: none;
      font-size: 13px;
      line-height: 1.45;
    }

    .invGrid{ display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .invCols{ display:grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .invCol{ padding: 12px; border-radius: 16px; border: 1px solid var(--border); background: rgba(255,255,255,0.05); min-height: 220px; }
    .invCol h3{ margin: 0 0 10px; font-size: 13.5px; display:flex; justify-content: space-between; align-items:center; gap: 10px; }
    .invCol .small{ color: var(--muted); font-size: 11.5px; }
    .invItem{
      padding: 10px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.22);
      margin-bottom: 10px;
      cursor: grab;
    }
    .invItem:active{ cursor: grabbing; }
    .invItem .name{ font-weight: 850; }
    .invItem .meta{ margin-top: 4px; font-size: 12px; color: var(--muted); display:flex; justify-content: space-between; gap: 8px; }
    .invItem .actions{ margin-top: 8px; display:flex; gap: 8px; flex-wrap: wrap; }

    .invForm{
      padding: 12px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.05);
    }
    .invForm .row2{ display:grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    .input{
      width: 100%;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,0.25);
      color: var(--text);
      outline: none;
      font-weight: 650;
      font-size: 13px;
    }

    .footerRow{
      margin-top: 12px;
      display:flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items:center;
      justify-content: space-between;
    }
    .saveHint{ color: var(--muted); font-size: 12px; }

    .diceFab{
      position: fixed;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(10px);
      display:grid;
      place-items:center;
      cursor: pointer;
      z-index: 50;
      box-shadow: 0 12px 30px rgba(0,0,0,0.40);
      transition: transform 120ms ease, background 120ms ease;
    }
    .diceFab:hover{ background: rgba(255,255,255,0.10); }
    .diceFab:active{ transform: translateY(-50%) scale(0.98); }
    .diceFab svg{ width: 22px; height: 22px; fill: none; stroke: rgba(255,255,255,0.92); stroke-width: 2; }

    .drawerOverlay{
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.50);
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease;
      z-index: 60;
    }
    .drawerOverlay.on{ opacity: 1; pointer-events: auto; }

    .drawer{
      position: fixed;
      top: 0;
      right: 0;
      height: 100%;
      width: min(420px, 92vw);
      transform: translateX(102%);
      transition: transform 220ms ease;
      z-index: 70;
      display:flex;
      flex-direction: column;
      background: rgba(15, 18, 26, 0.92);
      border-left: 1px solid rgba(255,255,255,0.14);
      box-shadow: -18px 0 40px rgba(0,0,0,0.45);
      backdrop-filter: blur(12px);
    }
    body[data-theme="parchment-crimson"] .drawer{ background: rgba(38, 30, 22, 0.92); }
    body[data-theme="glass-teal"] .drawer{ background: rgba(7, 28, 30, 0.92); }

    .drawer.on{ transform: translateX(0); }
    .drawerHead{
      padding: 14px 14px 10px;
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.14);
    }
    .drawerHead .ttl{ font-weight: 900; letter-spacing: 0.2px; }
    .drawerBody{ padding: 14px; overflow:auto; }
    .drawerClose{
      width: 38px;
      height: 38px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(255,255,255,0.06);
      color: rgba(255,255,255,0.92);
      cursor: pointer;
      display:grid;
      place-items:center;
    }

    .diceTop{ display:flex; gap: 10px; flex-wrap: wrap; align-items:center; }
    .rollAnim{
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(0,0,0,0.25);
      min-height: 120px;
      position: relative;
      overflow: hidden;
      margin-top: 12px;
    }
    .rollAnim .big{
      font-size: 46px;
      font-weight: 900;
      letter-spacing: 0.5px;
      text-shadow: 0 10px 30px rgba(0,0,0,0.45);
    }
    .rollAnim .small{
      position:absolute;
      bottom: 10px;
      left: 12px;
      right: 12px;
      display:flex;
      justify-content: space-between;
      color: var(--muted);
      font-size: 12px;
    }
    .log{
      margin-top: 10px;
      padding: 10px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.05);
      max-height: 220px;
      overflow:auto;
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.35;
      white-space: pre-wrap;
    }

    .pop{
      position: fixed;
      inset: 0;
      display:grid;
      place-items:center;
      pointer-events: none;
      z-index: 90;
    }
    .popCard{
      pointer-events: none;
      width: min(420px, 92vw);
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(0,0,0,0.68);
      backdrop-filter: blur(12px);
      box-shadow: 0 24px 60px rgba(0,0,0,0.55);
      padding: 16px 16px 14px;
      transform: translateY(14px) scale(0.98);
      opacity: 0;
      transition: opacity 180ms ease, transform 180ms ease;
      overflow:hidden;
      position: relative;
    }
    .popCard.on{ opacity: 1; transform: translateY(0) scale(1); }
    .popGlow{
      position:absolute;
      inset: -40px;
      background: radial-gradient(420px 240px at 30% 30%, rgba(255,255,255,0.12), transparent 60%),
