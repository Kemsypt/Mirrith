    function bindFields(){
      document.querySelectorAll("[data-k]").forEach(el=>{
        const key=el.getAttribute("data-k");
        if(key in state.fields){
          if(el.tagName==="INPUT"||el.tagName==="SELECT"||el.tagName==="TEXTAREA") el.value=state.fields[key]??"";
          else el.textContent=state.fields[key]??"";
        }
        const handler=()=>{
          if(el.tagName==="INPUT"||el.tagName==="SELECT"||el.tagName==="TEXTAREA"){
            const v=(el.type==="number")?Number(el.value):el.value;
            state.fields[key]=v;
          }else state.fields[key]=el.textContent;
          if(key.startsWith("hp")) updateHP();
          if(key==="dc"||key==="spellAtk") updateSpellHeader();
          saveSoon();
        };
        if(el.tagName==="INPUT"||el.tagName==="SELECT"||el.tagName==="TEXTAREA"){
          el.addEventListener("input",handler);
          el.addEventListener("change",handler);
        }else{
          el.addEventListener("input",handler);
          el.addEventListener("blur",handler);
        }
      });
      if(state.meta?.theme) document.body.setAttribute("data-theme", state.meta.theme);
    }

    const clamp=(n,a,b)=>Math.max(a,Math.min(b,n));
    function updateHP(){
      const cur=Number(state.fields.hpCur??0);
      const max=Math.max(1,Number(state.fields.hpMax??1));
      const temp=Math.max(0,Number(state.fields.hpTemp??0));
      const curClamped=clamp(cur,0,max);
      if(cur!==curClamped){
        state.fields.hpCur=curClamped;
        const hpCurEl=document.getElementById("hpCur"); if(hpCurEl) hpCurEl.value=curClamped;
      }
      const pct=Math.round((curClamped/max)*100);
      const fill=document.getElementById("hpFill"); if(fill) fill.style.width=pct+"%";
      const hpPct=document.getElementById("hpPct"); if(hpPct) hpPct.textContent=pct+"%";
      const hpLine=document.getElementById("hpLine"); if(hpLine) hpLine.textContent=`${curClamped}/${max}`;
      const st=document.getElementById("hpState");
      if(st){
        let label="Fine";
        if(curClamped===0) label="Down";
        else if(pct<=25) label="Rough";
        else if(pct<=50) label="Hurt";
        st.textContent=label;
      }
      const hpLineMeta=document.querySelector("#hpLine + span");
      if(hpLineMeta) hpLineMeta.textContent=`(+${temp} temp)`;
      if(pct<=25){ document.documentElement.style.setProperty("--hp","var(--bad)"); document.documentElement.style.setProperty("--hp2","rgba(255,107,107,.75)"); }
      else if(pct<=50){ document.documentElement.style.setProperty("--hp","var(--warn)"); document.documentElement.style.setProperty("--hp2","rgba(255,204,102,.75)"); }
      else { document.documentElement.style.setProperty("--hp","var(--good)"); document.documentElement.style.setProperty("--hp2","rgba(80,227,164,.78)"); }
    }

