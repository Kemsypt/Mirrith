      filter: blur(0px);
    }
    .popMain{
      position: relative;
      display:flex;
      gap: 14px;
      align-items:center;
    }
    .popNum{
      width: 74px;
      height: 74px;
      border-radius: 18px;
      display:grid;
      place-items:center;
      font-size: 34px;
      font-weight: 950;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.06);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);
    }
    .popText{ flex:1; min-width: 0; }
    .popTitle{ font-weight: 900; letter-spacing:0.2px; }
    .popDetail{ margin-top: 4px; color: rgba(255,255,255,0.78); font-size: 13px; line-height: 1.35; }
    .popHint{ margin-top: 8px; color: rgba(255,255,255,0.62); font-size: 12px; }

    .popCard[data-tone="normal"] .popNum{ border-color: rgba(255,255,255,0.18); }
    .popCard[data-tone="green"] .popNum{ border-color: rgba(80,227,164,0.55); box-shadow: 0 0 0 4px rgba(80,227,164,0.10); }
    .popCard[data-tone="red"] .popNum{ border-color: rgba(255,107,107,0.55); box-shadow: 0 0 0 4px rgba(255,107,107,0.10); }

    @media (max-width: 980px){
      header{ grid-template-columns: 1fr; }
      .spellGrid{ grid-template-columns: 1fr; }
      .notesGrid{ grid-template-columns: 1fr; }
      .invCols{ grid-template-columns: 1fr 1fr; }
      .miniGrid{ grid-template-columns: repeat(3, 1fr); }
      .skillGrid{ grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px){
      .invCols{ grid-template-columns: 1fr; }
      .miniGrid{ grid-template-columns: repeat(2, 1fr); }
      .skillGrid{ grid-template-columns: 1fr; }
      .diceFab{ right: 8px; }
    }
  </style>
</head>

