    async function rollWithAnimation(label, rollerFn){
      const animNum=document.getElementById("animNum"), animLeft=document.getElementById("animLeft"), animRight=document.getElementById("animRight");
      if(animLeft) animLeft.textContent=label;

      const start=performance.now(), dur=850;
      const tick=()=>{
        const t=performance.now(); const p=(t-start)/dur;
        const fake=randInt(1,20);
        if(animNum) animNum.textContent=String(fake);
        if(p<1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      await new Promise(r=>setTimeout(r,dur));

      const result=rollerFn();
      if(animNum) animNum.textContent=String(result.total);
      if(animRight) animRight.textContent=result.detail||"";
      addRollLog(result.logLine);

      const tone=(result.nat===20)?"green":(result.nat===1?"red":"normal");
      showPopup({ title: result.popupTitle||label, total: result.total, detail: result.detail||"", hint: result.popupHint||"", tone });
      return result;
    }

    function parseExpression(expr){
      const cleaned=(expr||"").replace(/\s+/g,"").toLowerCase();
      if(!cleaned) return null;
      if(!/^[0-9d+\-]+$/.test(cleaned)) return null;
      const tokens=[]; let cur="";
      for(let i=0;i<cleaned.length;i++){
        const c=cleaned[i];
        if((c==="+"||c==="-") && i!==0){ tokens.push(cur); cur=c; } else cur+=c;
      }
      if(cur) tokens.push(cur);
      const parts=tokens.map(t=>{
        const sign=t[0]==="-"?-1:1;
        const s=(t[0]==="+"||t[0]==="-")?t.slice(1):t;
        if(s.includes("d")){
          const [a,b]=s.split("d");
          const n=a===""?1:Number(a);
          const sides=Number(b);
          if(!Number.isFinite(n)||!Number.isFinite(sides)||n<=0||sides<=0) return null;
          return {type:"dice",sign,n,sides};
        }else{
          const k=Number(s);
          if(!Number.isFinite(k)) return null;
          return {type:"flat",sign,k};
        }
      });
      if(parts.some(p=>p===null)) return null;
      return parts;
    }

    async function rollD20(title, bonus, hint){
      const b=Number(String(bonus).replace("+",""))||0;
      return rollWithAnimation(title, ()=>{
        const nat=randInt(1,20);
        const total=nat+b;
        const detail=`${nat}${b?(b>=0?` + ${b}`:` - ${Math.abs(b)}`):""}`.trim();
        return {
          nat, total, detail,
          popupTitle:title,
          popupHint:hint||"",
          logLine:`${title}: d20${b?(b>=0?`+${b}`:`${b}`):""} = ${total} (${detail})`
        };
      });
    }

    async function rollDiceExpr(title, expr, hint){
      const parts=parseExpression(expr);
      if(!parts){
        showPopup({ title:"Invalid roll", total:"—", detail:expr, hint:"Use formats like 2d6+3 or d20+5", tone:"normal" });
        return null;
      }
      return rollWithAnimation(title, ()=>{
        let total=0; const chunks=[]; let nat=null;
        for(const p of parts){
          if(p.type==="flat"){
            total+=p.sign*p.k;
            chunks.push(`${p.sign===1?"+":"-"}${p.k}`);
          }else{
            const rolls=Array.from({length:p.n},()=>randInt(1,p.sides));
            const sum=rolls.reduce((a,b)=>a+b,0);
            total+=p.sign*sum;
            const core=`${p.n}d${p.sides}(${rolls.join(",")})=${sum}`;
            chunks.push(`${p.sign===1?"+":"-"}${core}`);
            if(p.sides===20 && p.n===1 && nat===null) nat=rolls[0];
            else if(nat!==null && (p.sides!==20 || p.n!==1)) nat=null;
          }
        }
        const detail=chunks.join(" ").replace(/^\+/,"").trim();
        return {
          nat, total, detail,
          popupTitle:title,
          popupHint:hint||"",
          logLine:`${title}: ${expr} = ${total} (${detail})`
        };
      });
    }

    function abilityMod(key){ const a=state.abilities.find(x=>x.key===key); return a?a.mod:0; }
    function calcSave(key){ const mod=abilityMod(key); const prof=state.saves[key]?.prof?state.proficiencyBonus:0; return mod+prof; }
    function calcSkill(skill){ const mod=abilityMod(skill.abil); const prof=skill.prof?state.proficiencyBonus:0; return mod+prof; }

