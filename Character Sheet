    }

    function renderSlots(){
      const dots=document.getElementById("slotDots");
      if(!dots) return;
      dots.innerHTML="";
      state.spells.slots=(state.spells.slots||[]).slice(0,state.spells.slotMax);
      while(state.spells.slots.length<state.spells.slotMax) state.spells.slots.push(true);
      state.spells.slotRemain=state.spells.slots.filter(Boolean).length;

      for(let i=0;i<state.spells.slotMax;i++){
        const d=document.createElement("div");
        d.className="slotDot "+(state.spells.slots[i]?"available":"used");
        d.title=state.spells.slots[i]?"Available":"Used";
        d.addEventListener("click",()=>{
          state.spells.slots[i]=!state.spells.slots[i];
          state.spells.slotRemain=state.spells.slots.filter(Boolean).length;
          renderSlots();
          saveSoon();
        });
        dots.appendChild(d);
      }
      const slotNum=document.getElementById("slotNum");
      if(slotNum) slotNum.textContent=String(state.spells.slotRemain);
    }

    function setRemain(n){
      const max=state.spells.slotMax;
      const remain=clamp(n,0,max);
      state.spells.slots=Array.from({length:max},(_,i)=>i<remain);
      state.spells.slotRemain=remain;
      renderSlots();
      saveSoon();
    }

    function useSlot(){
      if(state.spells.slotRemain<=0){
        showPopup({ title:"No slots left", total:"—", detail:"You’re out of 1st-level slots.", hint:"Reset on long rest, or use Arcane Recovery.", tone:"normal" });
        return false;
      }
      setRemain(state.spells.slotRemain-1);
      return true;
    }

    function renderSpellCard(sp, allowPreparedToggle){
      const card=document.createElement("div");
      card.className="spellCard";
      const tags=sp.tags.map(t=>`<span class="tag">${escapeHtml(t)}</span>`).join("");
      const preparedChip=allowPreparedToggle?`
        <div class="btn small" data-chip="prepared" data-id="${sp.id}" style="padding:8px 10px;">
          ${sp.prepared?"Prepared":"Not prepared"}
        </div>`:"";
      card.innerHTML=`
        <div class="spellTop">
          <div>
            <div class="spellName">${escapeHtml(sp.name)}</div>
            <div class="tagRow">${tags}</div>
          </div>
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; justify-content:flex-end;">
            ${preparedChip}
            <button class="btn small primary" data-cast="${sp.id}">Cast</button>
          </div>
        </div>

        <details>
          <summary>Spell details</summary>
          <div class="spellBody">
            <div class="line"><span class="lbl">Level:</span> ${sp.level===0?"Cantrip":sp.level}</div>
            <div class="line"><span class="lbl">School:</span> ${escapeHtml(sp.school)}</div>
            <div class="line"><span class="lbl">Casting Time:</span> ${escapeHtml(sp.castingTime)}</div>
            <div class="line"><span class="lbl">Range:</span> ${escapeHtml(sp.range)}</div>
            <div class="line"><span class="lbl">Components:</span> ${escapeHtml(sp.components)}</div>
            <div class="line"><span class="lbl">Duration:</span> ${escapeHtml(sp.duration)}</div>

            <div class="line" style="margin-top:10px;"><span class="lbl">Short:</span> ${escapeHtml(sp.summary)}</div>

            <div class="line" style="margin-top:10px;"><span class="lbl">Full description:</span></div>
            <div class="line" style="margin-top:6px;">${escapeHtml(sp.full)}</div>

            <div class="line" style="margin-top:10px;"><span class="lbl">Quick mechanics:</span></div>
            <ul style="margin:6px 0 0 18px; padding:0; color:rgba(255,255,255,.84)">
              ${sp.mechanics.map(m=>`<li><span class="lbl">${escapeHtml(m.k)}:</span> ${escapeHtml(m.v)}</li>`).join("")}
            </ul>

            <div class="line" style="margin-top:10px;"><span class="lbl">Notes:</span> <span contenteditable="true" data-spnote="${sp.id}">${escapeHtml(sp.notes||"")}</span></div>
          </div>
        </details>
      `;
      return card;
    }

    function renderSpells(){
      const cantripGrid=document.getElementById("cantripGrid");
      const level1Grid=document.getElementById("level1Grid");
      if(!cantripGrid||!level1Grid) return;
      cantripGrid.innerHTML="";
      level1Grid.innerHTML="";

      const cantrips=state.spells.list.filter(s=>s.level===0);
      const level1=state.spells.list.filter(s=>s.level===1);

      cantrips.forEach(sp=>cantripGrid.appendChild(renderSpellCard(sp,false)));
      level1.forEach(sp=>level1Grid.appendChild(renderSpellCard(sp,true)));

      level1Grid.querySelectorAll("[data-chip='prepared']").forEach(ch=>{
        ch.addEventListener("click",()=>{
          const id=ch.getAttribute("data-id");
          const spell=state.spells.list.find(s=>s.id===id);
          if(!spell) return;
          const nowOn=!spell.prepared;
          if(nowOn){
            const preparedCount=state.spells.list.filter(s=>s.level===1 && s.prepared).length;
            if(preparedCount>=state.spells.prepMax){
              showPopup({ title:"Prepared limit", total:"—", detail:`You can prepare ${state.spells.prepMax} spells.`, hint:"Unprepare one first.", tone:"normal" });
              return;
            }
          }
          spell.prepared=nowOn;
          ch.textContent=nowOn?"Prepared":"Not prepared";
          saveSoon();
        });
      });

      document.querySelectorAll("[data-spnote]").forEach(el=>{
        el.addEventListener("input",()=>{
          const id=el.getAttribute("data-spnote");
          const spell=state.spells.list.find(s=>s.id===id);
          if(!spell) return;
          spell.notes=el.textContent;
          saveSoon();
        });
      });

      document.querySelectorAll("[data-cast]").forEach(btn=>{
        btn.addEventListener("click", async ()=>{
          const id=btn.getAttribute("data-cast");
          const spell=state.spells.list.find(s=>s.id===id);
          if(!spell) return;

          if(spell.cast?.usesSlot){
            const ok=useSlot();
            if(!ok) return;
          }

          if(spell.cast?.dice){
            await rollDiceExpr(spell.cast.label||`Cast ${spell.name}`, spell.cast.dice, `Spell: ${spell.name}`);
          }else{
            showPopup({ title:`Cast ${spell.name}`, total:"✓", detail:spell.cast?.usesSlot?"Slot used.":"No slot used.", hint:"", tone:"normal" });
          }

          if(spell.id==="mage_armor"){
            const dexMod=abilityMod("dex");
            const newAC=13+dexMod;
            state.fields.ac=newAC;
            const acEl=document.querySelector("[data-k='ac']");
            if(acEl) acEl.value=newAC;
            saveSoon();
          }
        });
      });
    }

    function bindSlotButtons(){
      const up=document.getElementById("slotUp");
      const down=document.getElementById("slotDown");
      const reset=document.getElementById("slotReset");
      if(up) up.addEventListener("click",()=>setRemain(state.spells.slotRemain+1));
      if(down) down.addEventListener("click",()=>setRemain(state.spells.slotRemain-1));
      if(reset) reset.addEventListener("click",()=>setRemain(state.spells.slotMax));
    }

    const invCats=["Weapons","Gear","Consumables","Misc"];

    function renderInventory(){
      const cols=document.getElementById("invCols");
      if(!cols) return;
      cols.innerHTML="";

      invCats.forEach(cat=>{
        const col=document.createElement("div");
        col.className="invCol";
        col.setAttribute("data-cat",cat);
        col.innerHTML=`<h3>${cat} <span class="small" id="count_${cat}"></span></h3><div class="dropZone" style="min-height:140px;"></div>`;
        const zone=col.querySelector(".dropZone");

        zone.addEventListener("dragover",(e)=>{ e.preventDefault(); zone.style.outline="2px dashed rgba(255,255,255,.22)"; zone.style.borderRadius="14px"; });
        zone.addEventListener("dragleave",()=>{ zone.style.outline="none"; });
        zone.addEventListener("drop",(e)=>{
          e.preventDefault();
          zone.style.outline="none";
          const id=e.dataTransfer.getData("text/plain");
          const item=state.inventory.items.find(x=>x.id===id);
          if(!item) return;
          item.cat=cat;
          renderInventory();
          saveSoon();
        });

        const items=state.inventory.items.filter(i=>i.cat===cat);
        const countEl=col.querySelector(`#count_${cat}`);
        if(countEl) countEl.textContent=items.length?`(${items.length})`:"";

        items.forEach(item=>{
          const it=document.createElement("div");
          it.className="invItem";
          it.draggable=true;
          it.setAttribute("data-id", item.id);

          const isWeapon=(cat==="Weapons");
          it.innerHTML=`
            <div class="name">${escapeHtml(item.name)}</div>
            <div class="meta"><span>Qty: <b>${item.qty}</b></span><span>${escapeHtml(item.note||"")}</span></div>
            ${isWeapon?`
              <div class="actions">
                <button class="btn small" data-watk="${item.id}">Attack ${escapeHtml(item.atk||"")}</button>
                <button class="btn small" data-wdmg="${item.id}">Damage ${escapeHtml(item.dmg||"")}</button>
              </div>`:""}
          `;

          it.addEventListener("dragstart",(e)=>e.dataTransfer.setData("text/plain", item.id));
          it.addEventListener("click",()=>openEditModal(item.id));
          it.addEventListener("contextmenu",(e)=>{ e.preventDefault(); openEditModal(item.id,true); });

          zone.appendChild(it);
        });

        cols.appendChild(col);
      });

      document.querySelectorAll("[data-watk]").forEach(btn=>{
        btn.addEventListener("click",(e)=>{
          e.stopPropagation();
          const id=btn.getAttribute("data-watk");
          const item=state.inventory.items.find(x=>x.id===id);
          if(!item) return;
          const b=Number(String(item.atk||"+0").replace("+",""))||0;
          rollD20(`${item.name} attack`, b, `Attack bonus ${modString(b)}`);
        });
      });

      document.querySelectorAll("[data-wdmg]").forEach(btn=>{
        btn.addEventListener("click",(e)=>{
          e.stopPropagation();
          const id=btn.getAttribute("data-wdmg");
          const item=state.inventory.items.find(x=>x.id===id);
          if(!item) return;
          const expr=(item.dmg||"").trim();
          if(!expr){
            showPopup({ title:"No damage set", total:"—", detail:item.name, hint:"Edit the weapon to add a damage roll.", tone:"normal" });
            return;
          }
          rollDiceExpr(`${item.name} damage`, expr, "");
        });
      });
    }

    function bindInventoryForm(){
      const add=document.getElementById("addItem");
      const clear=document.getElementById("clearItems");
      const catEl=document.getElementById("itemCat");
      const weaponFields=document.getElementById("weaponFields");
      function updateWeaponFields(){ weaponFields.style.display=(catEl.value==="Weapons")?"block":"none"; }
      if(catEl){ catEl.addEventListener("change", updateWeaponFields); updateWeaponFields(); }

      if(add) add.addEventListener("click",()=>{
        const name=document.getElementById("itemName").value.trim();
        const qty=Number(document.getElementById("itemQty").value)||1;
        const cat=document.getElementById("itemCat").value;
        const note=document.getElementById("itemNote").value.trim();
        const atk=document.getElementById("weapAtk").value.trim();
        const dmg=document.getElementById("weapDmg").value.trim();

        if(!name){ showPopup({ title:"Name needed", total:"—", detail:"", hint:"", tone:"normal" }); return; }

        const id="i"+Math.random().toString(16).slice(2);
        const item={ id, name, qty:Math.max(1,qty), note, cat };
        if(cat==="Weapons"){ item.atk=atk||"+0"; item.dmg=dmg||""; }
        state.inventory.items.unshift(item);

        document.getElementById("itemName").value="";
        document.getElementById("itemNote").value="";
        document.getElementById("weapAtk").value="";
        document.getElementById("weapDmg").value="";

        renderInventory();
        saveSoon();
      });

      if(clear) clear.addEventListener("click",()=>{
        if(!confirm("Clear all inventory items?")) return;
        state.inventory.items=[];
        renderInventory();
        saveSoon();
      });
    }

    // themed edit modal
    let editId=null;

    function openEditModal(id, autoFocusDelete=false){
      const item=state.inventory.items.find(x=>x.id===id);
      if(!item) return;
      editId=id;

      const overlay=document.getElementById("modalOverlay");
      const modal=document.getElementById("editModal");
      document.getElementById("editTitle").textContent=`Edit: ${item.name}`;

      document.getElementById("editName").value=item.name;
      document.getElementById("editQty").value=item.qty;
      document.getElementById("editCat").value=item.cat;
      document.getElementById("editNote").value=item.note||"";

      const wf=document.getElementById("editWeaponFields");
      wf.style.display=(item.cat==="Weapons")?"block":"none";
      document.getElementById("editAtk").value=item.atk||"+0";
      document.getElementById("editDmg").value=item.dmg||"";

      document.getElementById("editCat").onchange=()=>{
        const cat=document.getElementById("editCat").value;
        document.getElementById("editWeaponFields").style.display=(cat==="Weapons")?"block":"none";
      };

      overlay.classList.add("on");
      modal.classList.add("on");

      if(autoFocusDelete) setTimeout(()=>document.getElementById("editDelete").focus(),50);
      else setTimeout(()=>document.getElementById("editName").focus(),50);
    }

    function closeEditModal(){
      document.getElementById("modalOverlay").classList.remove("on");
      document.getElementById("editModal").classList.remove("on");
      editId=null;
    }

    function bindEditModal(){
      const overlay=document.getElementById("modalOverlay");
      const close=document.getElementById("editClose");
      const cancel=document.getElementById("editCancel");
      const saveBtn=document.getElementById("editSave");
      const delBtn=document.getElementById("editDelete");

      const closeAll=()=>closeEditModal();
      overlay.addEventListener("click", closeAll);
      close.addEventListener("click", closeAll);
      cancel.addEventListener("click", closeAll);

      saveBtn.addEventListener("click",()=>{
        if(!editId) return;
        const item=state.inventory.items.find(x=>x.id===editId);
        if(!item) return;

        const name=document.getElementById("editName").value.trim();
        const qty=Math.max(1, Number(document.getElementById("editQty").value)||1);
        const cat=document.getElementById("editCat").value;
        const note=document.getElementById("editNote").value.trim();

        item.name=name||item.name;
        item.qty=qty;
        item.cat=cat;
        item.note=note;

        if(cat==="Weapons"){
          item.atk=(document.getElementById("editAtk").value.trim()||"+0");
          item.dmg=(document.getElementById("editDmg").value.trim()||"");
        }else{
          delete item.atk;
          delete item.dmg;
        }

        renderInventory();
        saveSoon();
        closeEditModal();
      });

      delBtn.addEventListener("click",()=>{
        if(!editId) return;
        const item=state.inventory.items.find(x=>x.id===editId);
        if(!item) return;
        if(!confirm(`Delete "${item.name}"?`)) return;
        state.inventory.items=state.inventory.items.filter(x=>x.id!==editId);
        renderInventory();
        saveSoon();
        closeEditModal();
      });

      document.addEventListener("keydown",(e)=>{
        if(e.key==="Escape"){
          if(document.getElementById("modalOverlay").classList.contains("on")) closeEditModal();
        }
      });
    }

    function renderNotes(){
      const grid=document.getElementById("notesGrid");
      if(!grid) return;
      grid.innerHTML="";

      const all=[...state.notes.builtIn.map(n=>({...n,custom:false})), ...state.notes.custom.map(n=>({...n,custom:true}))];
      all.forEach(n=>{
        const card=document.createElement("div");
        card.className="noteCard";
        card.innerHTML=`
          <div class="noteCardHead">
            <div class="ttl">${escapeHtml(n.title)}</div>
            ${n.custom?`<button class="btn small" data-delnote="${n.id}">Delete</button>`:""}
          </div>
          <textarea data-noteid="${n.id}" placeholder="Write here..."></textarea>
        `;
        const ta=card.querySelector("textarea");
        ta.value=n.custom?(n.text||""):(state.fields[n.key]||"");
        ta.addEventListener("input",()=>{
          if(n.custom){
            const ref=state.notes.custom.find(x=>x.id===n.id);
            if(ref) ref.text=ta.value;
          }else state.fields[n.key]=ta.value;
          saveSoon();
        });
        const del=card.querySelector("[data-delnote]");
        if(del){
          del.addEventListener("click",()=>{
            if(!confirm("Delete this note box?")) return;
            state.notes.custom=state.notes.custom.filter(x=>x.id!==n.id);
            renderNotes();
            saveSoon();
          });
        }
        grid.appendChild(card);
      });
    }

    function bindNotes(){
      const add=document.getElementById("addNoteBox");
      if(add) add.addEventListener("click",()=>{
        const title=prompt("New note box name:");
        if(!title) return;
        const id="n"+Math.random().toString(16).slice(2);
        state.notes.custom.unshift({ id, title:title.trim(), text:"" });
        renderNotes();
        saveSoon();
      });
    }

    function renderFamiliars(){
      const grid=document.getElementById("familiarGrid");
      if(!grid) return;
      grid.innerHTML="";
      state.familiars.forEach(f=>{
        const card=document.createElement("div");
        card.className="statBlock";
        card.innerHTML=`
          <div style="display:flex; align-items:baseline; justify-content:space-between; gap:10px;">
            <div style="font-weight:950; font-size:14px;">${escapeHtml(f.name)}</div>
            <div class="hint">${escapeHtml(f.sizeType)}</div>
          </div>
          <details>
            <summary>Show full stats</summary>
            <div class="blockLine"><span class="lbl">AC:</span> ${escapeHtml(f.ac)}</div>
            <div class="blockLine"><span class="lbl">HP:</span> ${escapeHtml(f.hp)}</div>
            <div class="blockLine"><span class="lbl">Speed:</span> ${escapeHtml(f.speed)}</div>
            <div class="blockLine"><span class="lbl">Stats:</span> ${escapeHtml(f.stats)}</div>
            ${f.skills?`<div class="blockLine"><span class="lbl">Skills:</span> ${escapeHtml(f.skills)}</div>`:""}
            <div class="blockLine"><span class="lbl">Senses:</span> ${escapeHtml(f.senses)}</div>
            ${(f.traits && f.traits.length)?`
              <div class="blockLine"><span class="lbl">Traits:</span></div>
              <ul style="margin:6px 0 0 18px; padding:0; color:rgba(255,255,255,.84)">
                ${f.traits.map(t=>`<li><b>${escapeHtml(t[0])}.</b> ${escapeHtml(t[1])}</li>`).join("")}
              </ul>`:""}
            ${(f.actions && f.actions.length)?`
              <div class="blockLine" style="margin-top:10px;"><span class="lbl">Actions:</span></div>
              <ul style="margin:6px 0 0 18px; padding:0; color:rgba(255,255,255,.84)">
                ${f.actions.map(a=>`<li><b>${escapeHtml(a[0])}.</b> ${escapeHtml(a[1])}</li>`).join("")}
              </ul>`:""}
          </details>
        `;
        grid.appendChild(card);
      });
    }

    function bindExportImport(){
      const ex=document.getElementById("btnExport");
      const file=document.getElementById("importFile");
      const reset=document.getElementById("btnReset");

      if(ex) ex.addEventListener("click",()=>{
        const blob=new Blob([JSON.stringify(state,null,2)], {type:"application/json"});
        const a=document.createElement("a");
        a.href=URL.createObjectURL(blob);
        a.download="mirrith-sheet.json";
        a.click();
        URL.revokeObjectURL(a.href);
      });

      if(file) file.addEventListener("change", async ()=>{
        const f=file.files?.[0];
        if(!f) return;
        const text=await f.text();
        try{
          const parsed=JSON.parse(text);
          if(!parsed.fields || !parsed.spells) throw new Error("Not a sheet file");
          state=parsed;
          rebuild();
          saveSoon();
          showPopup({ title:"Imported", total:"✓", detail:"", hint:"", tone:"normal" });
        }catch(e){ alert("Import failed: "+e.message); }
        file.value="";
      });

      if(reset) reset.addEventListener("click",()=>{
        if(!confirm("Reset sheet to defaults?")) return;
        state=deepClone(baseState);
        rebuild();
        saveSoon();
      });
    }

    function bindDiceDrawer(){
      const fab=document.getElementById("diceFab");
      const overlay=document.getElementById("drawerOverlay");
      const drawer=document.getElementById("drawer");
      const close=document.getElementById("drawerClose");

      function open(){ drawer.classList.add("on"); overlay.classList.add("on"); }
      function shut(){ drawer.classList.remove("on"); overlay.classList.remove("on"); }

      if(fab) fab.addEventListener("click", open);
      if(close) close.addEventListener("click", shut);
      if(overlay) overlay.addEventListener("click", shut);
      document.addEventListener("keydown",(e)=>{ if(e.key==="Escape") shut(); });
    }

    function bindDiceUI(){
      const modEl=document.getElementById("mod");
      const exprEl=document.getElementById("expr");
      const rollBtn=document.getElementById("rollBtn");
      const exprBtn=document.getElementById("exprBtn");

      const log=document.getElementById("rollLog");
      if(log) log.textContent=(state.ui.rollLog||[]).join("\n");

      let selectedDie=20;

      document.querySelectorAll("[data-die]").forEach(btn=>{
        btn.addEventListener("click", async ()=>{
          selectedDie=Number(btn.getAttribute("data-die"));
          const mod=Number((modEl?.value||"0").replace("+",""))||0;
          await rollWithAnimation(`Rolling d${selectedDie}`, ()=>{
            const nat=randInt(1,selectedDie);
            const total=nat+mod;
            const detail=`${nat} ${mod?(mod>=0?`+ ${mod}`:`- ${Math.abs(mod)}`):""}`.trim();
            return {
              nat: selectedDie===20?nat:null,
              total,
              detail,
              popupTitle:`d${selectedDie}`,
              popupHint: mod?`Modifier ${modString(mod)}`:"",
              logLine:`d${selectedDie}${mod?(mod>=0?`+${mod}`:`${mod}`):""} = ${total} (${detail})`
            };
          });
        });
      });

      if(rollBtn) rollBtn.addEventListener("click",()=>document.querySelector(`[data-die="${selectedDie}"]`)?.click());

      if(exprBtn) exprBtn.addEventListener("click", async ()=>{
        const expr=exprEl?.value||"";
        await rollDiceExpr("Expression", expr, "");
      });

      if(exprEl) exprEl.addEventListener("keydown",(e)=>{ if(e.key==="Enter") exprBtn?.click(); });
    }

    function rebuild(){
      bindFields();
      updateHP();
      renderAbilities();
      renderSkills();
      renderAttacks();
      updateSpellHeader();
      renderSlots();
      renderSpells();
      renderFamiliars();
      renderInventory();
      renderNotes();
      const log=document.getElementById("rollLog");
      if(log) log.textContent=(state.ui.rollLog||[]).join("\n");
    }

    function init(){
      load();
      bindTabs();
      bindTheme();
      bindExportImport();
      bindDiceDrawer();
      bindDiceUI();
      bindSlotButtons();
      bindInventoryForm();
      bindEditModal();
      bindNotes();
      rebuild();
    }

    init();
  </script>
</body>
</html>
