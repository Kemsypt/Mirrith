    function clamp(n, a, b){ return Math.max(a, Math.min(b, n)); }
    function updateHP(){
      const cur = Number(state.fields.hpCur ?? 0);
      const max = Math.max(1, Number(state.fields.hpMax ?? 1));
      const temp = Math.max(0, Number(state.fields.hpTemp ?? 0));

      const curClamped = clamp(cur, 0, max);
      if(cur !== curClamped){
        state.fields.hpCur = curClamped;
        const hpCurEl = document.getElementById("hpCur");
        if(hpCurEl) hpCurEl.value = curClamped;
      }

      const pct = Math.round((curClamped / max) * 100);
      const fill = document.getElementById("hpFill");
      if(fill) fill.style.width = pct + "%";

      const hpPct = document.getElementById("hpPct");
      if(hpPct) hpPct.textContent = pct + "%";

      const hpLine = document.getElementById("hpLine");
      if(hpLine) hpLine.textContent = `${curClamped}/${max}`;

      const st = document.getElementById("hpState");
      if(st){
        let label = "Fine";
        if(curClamped === 0) label = "Down";
        else if(pct <= 25) label = "Rough";
        else if(pct <= 50) label = "Hurt";
        st.textContent = label;
      }

      const hpLineMeta = document.querySelector("#hpLine + span");
      if(hpLineMeta) hpLineMeta.textContent = `(+${temp} temp)`;

      if(pct <= 25){
        document.documentElement.style.setProperty('--hp', 'var(--bad)');
        document.documentElement.style.setProperty('--hp2', 'rgba(255,107,107,0.75)');
      } else if(pct <= 50){
        document.documentElement.style.setProperty('--hp', 'var(--warn)');
        document.documentElement.style.setProperty('--hp2', 'rgba(255,204,102,0.75)');
      } else {
